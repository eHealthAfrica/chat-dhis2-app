"Move through the section list on the left and fill the required fields in "
"each section. The navigation highlights incomplete required fields."
msgstr ""
"Move through the section list on the left and fill the required fields in "
"each section. The navigation highlights incomplete required fields."

msgid "Required fields must be completed before you can submit the assessment."
msgstr "Required fields must be completed before you can submit the assessment."

msgid "Long section names wrap in the side navigation so you can still read them."
msgstr "Long section names wrap in the side navigation so you can still read them."

msgid "Capture coordinates when needed"
msgstr "Capture coordinates when needed"

msgid ""
"Coordinate fields let you enter latitude and longitude directly, or use the "
"current location button to fill both values automatically."
msgstr ""
"Coordinate fields let you enter latitude and longitude directly, or use the "
"current location button to fill both values automatically."

msgid "You can edit the coordinates after using current location."
msgstr "You can edit the coordinates after using current location."

msgid ""
"Both latitude and longitude must be valid before the field passes "
"validation."
msgstr ""
"Both latitude and longitude must be valid before the field passes "
"validation."

msgid "Save and resume drafts"
msgstr "Save and resume drafts"

msgid ""
"Use Save progress to keep an unfinished record. Drafts are grouped by user "
