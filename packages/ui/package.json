{
    "name": "@dhis2-chat/ui",
    "packageManager": "pnpm@10.14.0",
    "type": "commonjs",
    "version": "4.0.0",
    "module": "./build\\es\\index.js",
    "types": "./build/types/index.d.ts",
    "license": "MIT",
    "scripts": {
        "watch": "tsc --watch",
        "build": "d2-app-scripts build && tsc --emitDeclarationOnly --outDir ./build/types",
        "start": "concurrently -n build,types --hide types \"d2-app-scripts build --watch\" \"tsc --emitDeclarationOnly --outDir ./build/types --watch\"",
        "linter:check": "eslint . --config ../../eslint.config.mts",
        "deploy": "d2-app-scripts deploy",
        "tsc:check": "tsc --noEmit"
    },
    "main": "./build\\cjs\\index.js",
    "exports": {
        "import": "./build\\es\\index.js",
        "require": "./build\\cjs\\index.js",
        "types": "./build\\types\\index.d.ts"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "dependencies": {
        "clsx": "^2.1.0",
        "p-queue": "^8.1.0",
        "vite": "5.4.21"
    },
    "devDependencies": {
        "@dhis2/cli-app-scripts": "12.8.0-alpha.3",
        "@types/css-modules": "^1.0.5",
        "@types/node": "^22.10.1",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.7.2"
    }
}
